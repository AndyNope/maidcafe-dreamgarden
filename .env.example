# Environment Variables — copy to .env and fill in values

# Database
DB_ROOT_PASSWORD=rootpassword
DB_NAME=maidcafe
DB_USER=maidcafe
DB_PASSWORD=maidcafe_secret

# JWT — change this to a long random string in production!
JWT_SECRET=change_this_in_production_please

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Frontend API URL (used in Vite build)
VITE_API_URL=http://localhost:8080
